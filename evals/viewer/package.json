{
  "name": "origami-viewer",
  "version": "2.0.0",
  "description": "ORIGAMI comparison viewer: Node.js server + standalone HTML frontend",
  "main": "viewer-server.js",
  "scripts": {
    "start": "node viewer-server.js",
    "dev": "PORT=8084 nodemon viewer-server.js",
    "bench": "bash ../scripts/bench_vegeta.sh --duration 15 --rates 50,100,200,400",
    "bench:jxl80": "bash ../scripts/bench_vegeta.sh --duration 15 --rates 50,100,200,400 --slide-filter jxl80",
    "bench:jxl40": "bash ../scripts/bench_vegeta.sh --duration 15 --rates 50,100,200,400 --slide-filter jxl40",
    "bench:all": "bash ../scripts/run_bench_suite.sh",
    "bench:report": "uv run python ../scripts/bench_report.py"
  },
  "dependencies": {
    "express": "^4.18.2",
    "http-proxy-middleware": "^3.0.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "packageManager": "pnpm@8.15.0"
}
